model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String?  @unique
  avatar    String?
  role      String   @default("user")
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  accounts Account[]
  novels   Novel[]
  sessions Session[]

  @@map("users")
}
